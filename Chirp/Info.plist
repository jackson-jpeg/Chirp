<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.chirpchirp.mesh.refresh</string>
		<string>com.chirpchirp.swarm.compute</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>ChirpChirp</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_chirp-ptt._udp.</string>
		<string>_chirp-ptt._tcp.</string>
	</array>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ChirpChirp uses your location to share GPS coordinates with nearby devices and for emergency SOS beacons.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ChirpChirp uses background location to keep emergency SOS beacons broadcasting your position.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>ChirpChirp uses your local network to discover and connect to nearby devices for walkie-talkie communication.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>ChirpChirp needs microphone access to transmit your voice to nearby devices.</string>
	<key>NSCameraUsageDescription</key>
	<string>ChirpChirp uses your camera to take photos and share them with nearby devices.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ChirpChirp accesses your photo library to share images with nearby devices.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>ChirpChirp saves received images to your photo library.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>NSNearbyInteractionUsageDescription</key>
	<string>ChirpChirp uses Ultra-Wideband to precisely locate nearby mesh peers for indoor positioning.</string>
	<key>NSMotionUsageDescription</key>
	<string>ChirpChirp uses motion sensors for dead reckoning navigation when GPS is unavailable.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>ChirpChirp uses speech recognition for real-time voice translation between languages.</string>
</dict>
</plist>
