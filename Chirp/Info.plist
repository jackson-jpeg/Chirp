<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.chirpchirp.mesh.refresh</string>
		<string>com.chirpchirp.swarm.compute</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>ChirpChirps</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>ChirpChirps uses Bluetooth to discover nearby devices for peer-to-peer communication.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_chirp-ptt._udp</string>
		<string>_chirp-ptt._tcp</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>ChirpChirps uses your camera to capture and share media with nearby devices.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>ChirpChirps uses your local network to connect directly to nearby devices without internet.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>ChirpChirps uses background location for emergency SOS broadcasting in critical situations.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>ChirpChirps uses your location to share your position with nearby peers.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>ChirpChirps uses your microphone for real-time voice communication with nearby devices.</string>
	<key>NSMotionUsageDescription</key>
	<string>ChirpChirps uses motion sensors to improve positioning when GPS is unavailable.</string>
	<key>NSNearbyInteractionUsageDescription</key>
	<string>ChirpChirps uses Ultra-Wideband to precisely locate nearby mesh peers for indoor positioning.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>ChirpChirps saves received images to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>ChirpChirps accesses your photo library to share images with nearby devices.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>ChirpChirps uses speech recognition for real-time translation of voice communication.</string>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
</dict>
</plist>
